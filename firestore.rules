rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // Chanpha Resort — Firestore Security Rules
    // =====================================================
    // Owner UID: UuSyhl057OdUcvznOgsrq1lHhct2
    // (email: owner@janchpa.internal)
    // If owner account changes: update this UID and redeploy
    //   firebase deploy --only firestore:rules
    // =====================================================

    function isOwner() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/my-resort-app-v1/public/data/ownerSessions/$(request.auth.uid));
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ROOMS — staff: read + cleaningStatus/maintenanceNote update only; owner: full
    match /artifacts/{appId}/public/data/rooms/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner();
      allow update: if isOwner() ||
        (isAuthenticated() && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['cleaningStatus', 'maintenanceNote']));
    }

    // BOOKINGS — staff: read + create + update (operational fields only); owner: full + delete
    match /artifacts/{appId}/public/data/bookings/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isOwner();
      allow update: if isOwner() ||
        (isAuthenticated() && !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['totalPrice', 'discount', 'roomPrice',
                                  'extraBedPrice', 'deposit']));
    }

    // EXPENSES — owner only
    match /artifacts/{appId}/public/data/expenses/{docId} {
      allow read, write: if isOwner();
    }

    // CONSUMABLES — staff read + update stock fields; owner full write
    match /artifacts/{appId}/public/data/consumables/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner();
      allow update: if isOwner() ||
        (isAuthenticated() && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['roomStock', 'stockQty']));
    }

    // OWNER SESSIONS — anonymous UID marked as owner after PIN verification
    match /artifacts/{appId}/public/data/ownerSessions/{uid} {
      allow read: if isAuthenticated();
      allow write, delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // CONSUMABLE LOGS — staff read + create; owner full; no staff delete (logs are immutable)
    match /artifacts/{appId}/public/data/consumableLogs/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner();
    }

    // CONSUMABLE CATEGORIES — staff read; owner write
    match /artifacts/{appId}/public/data/consumableCategories/{docId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }

  }
}
